NEXT_PUBLIC_IDENTITY_REGISTRY_ADDRESS=0xYourDeployedIdentityRegistryAddress
NEXT_PUBLIC_APPOINTMENT_REGISTRY_ADDRESS=0xYourDeployedAppointmentRegistryAddress
NEXT_PUBLIC_MEDICAL_RECORD_NFT_ADDRESS=0xYourDeployedMedicalRecordNFTAddress
NEXT_PUBLIC_MEDICAL_RECORD_REGISTRY_ADDRESS=0xYourDeployedMedicalRecordRegistryAddress
NEXT_PUBLIC_ACCESS_CONTROL_REGISTRY_ADDRESS=0xYourDeployedAccessControlRegistryAddress
NEXT_PUBLIC_CLAIM_REGISTRY_ADDRESS=0xYourDeployedClaimRegistryAddress
NEXT_PUBLIC_VISIT_REGISTRY_ADDRESS=0xYourDeployedVisitRegistryAddress
NEXT_PUBLIC_REFERRAL_REGISTRY_ADDRESS=0xYourDeployedReferralRegistryAddress

# Pinata JWT for IPFS uploads (Pinata dashboard -> API Keys -> New Key -> copy the JWT).
# No NEXT_PUBLIC_ prefix on purpose — this must stay server-side only,
# used by src/app/api/upload/route.js, never sent to the browser.
PINATA_JWT=your_pinata_jwt_here

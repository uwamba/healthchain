# Sepolia RPC endpoint (e.g. from Infura, Alchemy, or a public endpoint)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# Private key of the wallet that deploys the contracts to Sepolia.
# NEVER commit a real value here — this file is a template only.
# Use a dedicated test wallet, never one holding real funds.
DEPLOYER_PRIVATE_KEY=your_private_key_here
